# ==============================================================================
# 🔐 LOCAL PROXY SERVER - ENVIRONMENT VARIABLES
# ==============================================================================
# COPY this file to '.env' and fill in your actual API key.
# DO NOT commit '.env' to version control!
# ==============================================================================

# ------------------------------------------------------------------------------
# Gemini API Configuration
# ------------------------------------------------------------------------------
# Your Google Gemini API Key (Get it from https://ai.google.dev/)
# This is REQUIRED - the server will fail to start without it.
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------------------------
# Server Configuration (Optional)
# ------------------------------------------------------------------------------
# Host address to bind the server to (default: 0.0.0.0 for all interfaces)
HOST=0.0.0.0

# Port number for the server (default: 8000)
PORT=8000