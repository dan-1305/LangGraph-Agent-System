# ==============================================================================
# 🔐 GEMINI CLI ENVIRONMENT VARIABLES (TEMPLATE)
# ==============================================================================
# COPY this file to '.env' and fill in your actual API key.
# DO NOT commit '.env' to version control!
# ==============================================================================

# ------------------------------------------------------------------------------
# Google Gemini API Configuration
# ------------------------------------------------------------------------------
# Get your API key from: https://aistudio.google.com/app/apikey
GCLI_API_KEY=your_gemini_api_key_here

# Optional: Custom base URL (defaults to Google's official endpoint)
# GCLI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Optional: Model name (defaults to gemini-1.5-flash)
# Available models: gemini-1.5-flash, gemini-1.5-pro, gemini-2.5-flash
# GCLI_MODEL=gemini-1.5-flash

# Optional: Request timeout in seconds (defaults to 60)
# GCLI_TIMEOUT=60