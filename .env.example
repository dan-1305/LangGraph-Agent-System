# ==============================================================================
# 🔐 SYSTEM ENVIRONMENT VARIABLES (TEMPLATE)
# ==============================================================================
# COPY this file to '.env' and fill in your actual API keys.
# DO NOT commit '.env' to version control!
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. AI Models (LangChain / LangGraph)
# ------------------------------------------------------------------------------
# Using Gemini 2.5 Flash and 3.1 Pro via proxy or direct API
GCLI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GCLI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------------------------
# 2. AI Trading Agent (Binance Testnet / Live)
# ------------------------------------------------------------------------------
# Leave empty for Paper Trading. Fill to enable Live Testnet execution.
BINANCE_TESTNET_API_KEY=your_binance_testnet_api_key_here
BINANCE_TESTNET_SECRET=your_binance_testnet_secret_here
BINANCE_TESTNET=True

# ------------------------------------------------------------------------------
# 3. Notifications & Alerts
# ------------------------------------------------------------------------------
# Telegram bot for sending Trading alerts / logs
TELE_TOKEN=your_telegram_bot_token_here
CHAT_ID=your_telegram_chat_id_here

# ------------------------------------------------------------------------------
# 4. Airdrop Guerrilla & Web Automation
# ------------------------------------------------------------------------------
# Token for Discord bot automations
DISCORD_TOKEN=your_discord_token_here

# ------------------------------------------------------------------------------
# 5. Database & System Settings
# ------------------------------------------------------------------------------
# SQLite is used by default in the 'data' directory.
# This variable can be used later if migrating to PostgreSQL.
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname
